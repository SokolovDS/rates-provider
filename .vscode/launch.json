{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python: Telegram Bot",
            "type": "debugpy",
            "request": "launch",
            "python": "/usr/bin/python3",
            "module": "rates_provider",
            "cwd": "${workspaceFolder}",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "Python: Tests (pytest)",
            "type": "debugpy",
            "request": "launch",
            "python": "/usr/bin/python3",
            "module": "pytest",
            "cwd": "${workspaceFolder}",
            "args": [
                "tests",
                "-q"
            ],
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ]
}