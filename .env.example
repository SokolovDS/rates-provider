# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=replace_with_your_real_token

# Repository backend: sqlite or memory
STORAGE_BACKEND=sqlite

# SQLite database file path for Rates Provider storage
SQLITE_RATES_DB_PATH=data/exchange_rates.sqlite3

# SQLite database file path for Users Service storage
SQLITE_USERS_DB_PATH=data/users_service.sqlite3
